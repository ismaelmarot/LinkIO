generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  name      String?
  password  String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  activities Activity[]
  routes     Route[]
  events     Event[]
  participants EventParticipant[]
}

model Activity {
  id          String   @id @default(cuid())
  userId      String
  sportType   String
  startTime   DateTime
  endTime     DateTime?
  duration    Int?
  distance    Float?
  avgSpeed    Float?
  maxSpeed    Float?
  elevation   Float?
  calories    Int?
  status      String   @default("active")
  routeId     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user   User      @relation(fields: [userId], references: [id])
  points GPSPoint[]
  route  Route?    @relation(fields: [routeId], references: [id])
}

model GPSPoint {
  id         String   @id @default(cuid())
  activityId String
  latitude   Float
  longitude  Float
  altitude   Float?
  speed      Float?
  timestamp  DateTime

  activity Activity @relation(fields: [activityId], references: [id])

  @@index([activityId])
}

model Route {
  id          String     @id @default(cuid())
  userId      String
  name        String
  description String?
  distance    Float?
  duration    Int?
  sportType   String?
  isPublic    Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user         User      @relation(fields: [userId], references: [id])
  activities   Activity[]
  events       Event[]
}

model Event {
  id             String     @id @default(cuid())
  userId         String
  title          String
  description    String?
  date           DateTime
  location       String?
  latitude       Float?
  longitude      Float?
  photoUrl       String?
  difficulty     String?
  maxParticipants Int?
  privacy        String     @default("public")
  isFavorite     Boolean    @default(false)
  isTemplate     Boolean    @default(false)
  routeId        String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  user         User              @relation(fields: [userId], references: [id])
  route        Route?            @relation(fields: [routeId], references: [id])
  participants EventParticipant[]
}

model EventParticipant {
  id      String @id @default(cuid())
  eventId String
  userId  String

  event Event @relation(fields: [eventId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@unique([eventId, userId])
}
